# Caddy config for the ThinkRight static site on Railway.
# Railway injects the listen port via $PORT.

{
	admin off
	persist_config off
	auto_https off
}

:{$PORT:8080} {
	root * /srv

	encode zstd gzip

	# 301 redirect /index.html (and /index) -> /
	@indexHtml path /index.html /index
	redir @indexHtml / 301

	# 301 redirect /foo.html -> /foo
	@pageHtml path_regexp pageHtml ^/(.+)\.html$
	redir @pageHtml /{re.pageHtml.1} 301

	# Serve clean URLs: /about -> about.html, / -> index.html
	try_files {path} {path}.html {path}/index.html /index.html

	# Long cache for static assets
	@assets path /assets/* *.css *.js *.svg *.png *.jpg *.woff2
	header @assets Cache-Control "public, max-age=2592000"

	# HTML should always revalidate
	@html path / *.html
	header @html Cache-Control "no-cache"

	file_server
}
